BRANDFETCH_CLIENT_ID=
# BRANDFETCH_API_KEY=
ENABLE_BRANDFETCH_BRAND_API=false
LOGO_OUTPUT_FORMAT=webp
LOGO_SIZE=512
LOGO_WEBP_QUALITY=82
ASSET_BUDGET_MB=20

BRANDFETCH_SCRAPE_MIN_DELAY_MS=10000
BRANDFETCH_SCRAPE_MAX_DELAY_MS=20000
# {domain} 会被替换为品牌域名
BRANDFETCH_SCRAPE_URL_TEMPLATE=https://brandfetch.com/{domain}
# 可选：使用系统 Chrome，而不是 Playwright 自带 Chromium。Windows 常用 chrome。
BRANDFETCH_SCRAPE_BROWSER_CHANNEL=
# 可选：复用/指定浏览器用户数据目录；建议使用单独目录，避免和正在运行的 Chrome 主配置冲突。
BRANDFETCH_SCRAPE_USER_DATA_DIR=
# 可选：仅在确有需要时指定；留空时使用浏览器自身真实 UA。
BRANDFETCH_SCRAPE_USER_AGENT=
