page {
  background: #ffffff;
}

.quiz-page,
.empty-page {
  min-height: 100vh;
  background: #ffffff;
  color: #3c3c3c;
  box-sizing: border-box;
  overflow-x: hidden;
}

.top-bar {
  padding-left: 24rpx;
  display: flex;
  align-items: center;
  gap: 22rpx;
  box-sizing: border-box;
}

.exit-icon {
  width: 58rpx;
  height: 58rpx;
  min-width: 58rpx;
  color: #afafaf;
  font-size: 52rpx;
  line-height: 58rpx;
  font-weight: 700;
  text-align: center;
  flex-shrink: 0;
}

.progress-track {
  flex: 1;
  min-width: 80rpx;
  height: 28rpx;
  border-radius: 999rpx;
  background: #e5e5e5;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.45), rgba(255, 255, 255, 0)), #58cc02;
  transition: width 0.2s ease;
}

.stage-card {
  width: calc(100% - 64rpx);
  min-height: 360rpx;
  margin: 24rpx auto 0;
  padding: 36rpx 32rpx;
  border-radius: 40rpx;
  border: 4rpx solid #e5e5e5;
  background: #ffffff;
  box-shadow: 0 10rpx 0 rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.type-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(88, 204, 2, 0.12);
  color: #46a302;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 900;
}

.stage-title {
  margin-top: 22rpx;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #3c3c3c;
  text-align: center;
}

.logo-question-image {
  width: 240rpx;
  height: 240rpx;
  margin-top: 28rpx;
}

.brand-question-name {
  max-width: 100%;
  margin-top: 36rpx;
  font-size: 56rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #3c3c3c;
  text-align: center;
  overflow-wrap: break-word;
}

.round-meta {
  width: calc(100% - 64rpx);
  margin: 22rpx auto 0;
  display: flex;
  justify-content: space-between;
  color: #afafaf;
  font-size: 24rpx;
  font-weight: 800;
}

.options-area {
  width: 100%;
  padding: 32rpx;
  padding-bottom: 220rpx;
  box-sizing: border-box;
}

.text-options {
  width: calc(100vw - 64rpx);
  max-width: calc(100vw - 64rpx);
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-btn,
.logo-option-btn {
  width: 100% !important;
  max-width: none;
  margin: 0 !important;
  background: #ffffff;
  border: 4rpx solid #e5e5e5;
  border-bottom: 10rpx solid #d9d9d9;
  border-radius: 28rpx;
  color: #3c3c3c;
  box-sizing: border-box;
  transition: transform 0.12s ease, border-bottom-width 0.12s ease;
}

.option-btn {
  min-height: 96rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  gap: 22rpx;
  text-align: left;
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 800;
  background-clip: padding-box;
}

.option-letter {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #f5f7fa;
  color: #afafaf;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 26rpx;
  font-weight: 900;
}

.option-btn text {
  flex: 1;
  min-width: 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.logo-options {
  width: calc(100vw - 64rpx);
  max-width: calc(100vw - 64rpx);
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.logo-option-btn {
  position: relative;
  height: 220rpx;
  padding: 0;
  line-height: normal;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.logo-option-letter {
  position: absolute;
  left: 22rpx;
  top: 20rpx;
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f5f7fa;
  color: #afafaf;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 900;
  z-index: 1;
}

.logo-option-btn image {
  width: 150rpx;
  height: 150rpx;
}

.option-active {
  transform: translateY(6rpx);
  border-bottom-width: 4rpx;
}

.selected {
  background: #eaf7ff !important;
  border-color: #1cb0f6 !important;
  border-bottom-color: #0789d8 !important;
}

.selected .option-letter {
  background: #1cb0f6;
  color: #ffffff;
}

.selected .logo-option-letter {
  background: #1cb0f6;
  color: #ffffff;
}

.correct {
  background: #e9f8df !important;
  border-color: #58cc02 !important;
  border-bottom-color: #3fa000 !important;
}

.correct .option-letter {
  background: #58cc02;
  color: #ffffff;
}

.correct .logo-option-letter {
  background: #58cc02;
  color: #ffffff;
}

.wrong {
  background: #ffecec !important;
  border-color: #ff4b4b !important;
  border-bottom-color: #d93232 !important;
}

.wrong .option-letter {
  background: #ff4b4b;
  color: #ffffff;
}

.wrong .logo-option-letter {
  background: #ff4b4b;
  color: #ffffff;
}

.disabled {
  opacity: 0.62;
}

.answer-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  min-height: 144rpx;
  padding: 24rpx 20rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 2rpx solid #e5e5e5;
  z-index: 20;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  box-sizing: border-box;
  transition: background 0.28s ease, border-color 0.28s ease, transform 0.28s ease;
}

.footer-correct {
  background: #d7ffb8;
  border-top: 4rpx solid #58cc02;
  animation: footer-slide 0.28s ease;
}

.footer-wrong {
  background: #ffdddd;
  border-top: 4rpx solid #ff4b4b;
  animation: footer-slide 0.28s ease;
}

@keyframes footer-slide {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.check-btn,
.footer-btn {
  width: calc(100vw - 40rpx) !important;
  max-width: none !important;
  height: 104rpx;
  margin: 0 !important;
  border-radius: 28rpx;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  box-sizing: border-box;
  display: flex !important;
  align-items: center;
  justify-content: center;
}

.check-btn {
  background: #e5e5e5;
  color: #afafaf;
}

.check-btn.is-ready {
  background: #58cc02;
  color: #ffffff;
  border-bottom: 8rpx solid #46a302;
}

.check-active {
  transform: translateY(5rpx);
  border-bottom-width: 3rpx !important;
}

.feedback-content {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  gap: 22rpx;
}

.feedback-title {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: #3c3c3c;
}

.feedback-desc {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.35;
  color: #3c3c3c;
}

.footer-btn {
  width: 100%;
  flex-shrink: 0;
  color: #ffffff;
}

.continue-btn {
  background: #58cc02;
  border-bottom: 8rpx solid #46a302;
}

.wrong-btn {
  background: #ff4b4b;
  border-bottom: 8rpx solid #d93232;
}

.empty-top {
  justify-content: flex-start;
}

.empty-card {
  width: calc(100% - 64rpx);
  margin: 120rpx auto 0;
  padding: 42rpx 32rpx;
  border-radius: 36rpx;
  border: 4rpx solid #e5e5e5;
  background: #ffffff;
  box-shadow: 0 10rpx 0 rgba(0, 0, 0, 0.05);
  text-align: center;
  box-sizing: border-box;
}

.empty-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #3c3c3c;
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #8a8a8a;
}

.empty-card button {
  margin-top: 30rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: #1cb0f6;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.2;
}

.option-btn::after,
.logo-option-btn::after,
.check-btn::after,
.footer-btn::after,
.empty-card button::after {
  border: 0;
}
