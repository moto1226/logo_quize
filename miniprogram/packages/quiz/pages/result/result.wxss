page {
  background: #ffffff;
}

.result-page {
  min-height: 100vh;
  background: #ffffff;
  color: #3c3c3c;
  box-sizing: border-box;
  overflow: hidden;
}

.safe-header {
  padding-left: 32rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  box-sizing: border-box;
}

.nav-title {
  font-size: 38rpx;
  line-height: 1;
  font-weight: 800;
  color: #3c3c3c;
}

.result-scroll {
  width: 100%;
  box-sizing: border-box;
}

.content {
  padding: 0 32rpx 52rpx;
  box-sizing: border-box;
}

.duo-card {
  background: #ffffff;
  border: 4rpx solid #e5e5e5;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 0 rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.hero-card {
  padding: 40rpx 32rpx 42rpx;
  border-radius: 40rpx;
  text-align: center;
  margin-bottom: 28rpx;
}

.hero-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 900;
}

.hero-score {
  margin-top: 12rpx;
  font-size: 96rpx;
  line-height: 1;
  font-weight: 900;
}

.score-green { color: #58cc02; }
.score-orange { color: #ff9600; }
.score-red { color: #ff4b4b; }

.hero-sub {
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #3c3c3c;
}

.hero-comment {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #777777;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.metric-card {
  min-height: 168rpx;
  padding: 24rpx;
}

.metric-value {
  font-size: 38rpx;
  line-height: 1.15;
  font-weight: 900;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric-label {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #3c3c3c;
}

.metric-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.25;
  color: #afafaf;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.metric-green .metric-value { color: #58cc02; }
.metric-blue .metric-value { color: #1cb0f6; }
.metric-orange .metric-value { color: #ff9600; }
.metric-purple .metric-value { color: #b87cf8; }

.metric-green {
  background: #f0ffe8;
  border-color: rgba(88, 204, 2, 0.42);
  box-shadow: 0 8rpx 0 rgba(70, 163, 2, 0.18);
}

.metric-blue {
  background: #eff8ff;
  border-color: rgba(28, 176, 246, 0.4);
  box-shadow: 0 8rpx 0 rgba(28, 176, 246, 0.16);
}

.metric-orange {
  background: #fff7e8;
  border-color: rgba(255, 150, 0, 0.4);
  box-shadow: 0 8rpx 0 rgba(255, 150, 0, 0.16);
}

.metric-purple {
  background: #f8f0ff;
  border-color: rgba(184, 124, 248, 0.42);
  box-shadow: 0 8rpx 0 rgba(184, 124, 248, 0.16);
}

.insight-card {
  margin-bottom: 28rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #eef7ff;
  display: flex;
  align-items: flex-start;
  box-sizing: border-box;
}

.insight-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 20rpx;
  background: #1cb0f6;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 34rpx;
  font-weight: 900;
}

.insight-copy {
  min-width: 0;
  margin-left: 20rpx;
  flex: 1;
}

.insight-title {
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
}

.insight-text {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #3c3c3c;
}

.section-card {
  padding: 28rpx;
  margin-bottom: 28rpx;
}

.section-title {
  margin-bottom: 22rpx;
  font-size: 32rpx;
  line-height: 1.25;
  font-weight: 900;
}

.type-row {
  margin-bottom: 24rpx;
}

.type-row:last-child {
  margin-bottom: 0;
}

.row-main {
  display: flex;
  align-items: center;
}

.type-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.type-green .type-dot,
.type-green .mini-track view { background: #58cc02; }
.type-blue .type-dot,
.type-blue .mini-track view { background: #1cb0f6; }
.type-orange .type-dot,
.type-orange .mini-track view { background: #ff9600; }
.type-purple .type-dot,
.type-purple .mini-track view { background: #b87cf8; }

.row-copy {
  min-width: 0;
  flex: 1;
  margin-left: 18rpx;
}

.row-title {
  font-size: 28rpx;
  line-height: 1.25;
  font-weight: 900;
}

.row-desc {
  margin-top: 6rpx;
  font-size: 23rpx;
  line-height: 1.3;
  color: #8a8a8a;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.row-score {
  margin-left: 18rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.mini-track {
  height: 16rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: #e5e5e5;
  overflow: hidden;
}

.mini-track view {
  height: 100%;
  border-radius: 999rpx;
}

.industry-row {
  margin-bottom: 20rpx;
}

.industry-row:last-child {
  margin-bottom: 0;
}

.industry-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  font-size: 26rpx;
  line-height: 1.3;
  font-weight: 800;
}

.industry-head text:first-child {
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.industry-head text:last-child {
  flex-shrink: 0;
  color: #58cc02;
}

.industry-track view {
  background: #58cc02;
}

.wrong-card {
  position: relative;
  padding: 22rpx 22rpx 22rpx 30rpx;
  margin-bottom: 16rpx;
  border-radius: 24rpx;
  background: #fff7f7;
  border: 3rpx solid #ffe1e1;
  box-sizing: border-box;
}

.wrong-card:last-child {
  margin-bottom: 0;
}

.wrong-mark {
  position: absolute;
  left: 0;
  top: 22rpx;
  bottom: 22rpx;
  width: 8rpx;
  border-radius: 999rpx;
  background: #ff4b4b;
}

.wrong-type {
  font-size: 25rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #3c3c3c;
}

.wrong-line {
  margin-top: 8rpx;
  font-size: 25rpx;
  line-height: 1.35;
  color: #777777;
}

.right-answer {
  color: #46a302;
  font-weight: 900;
}

.bad-answer {
  color: #ff4b4b;
  font-weight: 900;
}

.wrong-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.35;
  color: #afafaf;
}

.success-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #46a302;
  font-size: 26rpx;
  line-height: 1.45;
  font-weight: 800;
}

.success-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #58cc02;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.empty-line {
  color: #afafaf;
  font-size: 26rpx;
  line-height: 1.4;
}

.action-area {
  display: grid;
  gap: 20rpx;
  padding-bottom: 24rpx;
}

.primary-action,
.secondary-action,
.empty-state button {
  width: 100%;
  height: 96rpx;
  margin: 0;
  border-radius: 28rpx;
  font-size: 32rpx;
  line-height: 1.2;
  font-weight: 900;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-action {
  background: #58cc02;
  color: #ffffff;
  border-bottom: 8rpx solid #46a302;
}

.secondary-action {
  background: #ffffff;
  color: #3c3c3c;
  border: 4rpx solid #e5e5e5;
  border-bottom: 8rpx solid #d9d9d9;
}

.button-active {
  transform: translateY(4rpx);
  box-shadow: none;
}

.empty-state {
  padding: 120rpx 32rpx 0;
  text-align: center;
}

.empty-icon {
  width: 112rpx;
  height: 112rpx;
  margin: 0 auto 28rpx;
  border-radius: 34rpx;
  background: #eef7ff;
  color: #1cb0f6;
  border: 4rpx solid #e5e5e5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
  font-weight: 900;
}

.empty-title {
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 900;
}

.empty-desc {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #8a8a8a;
}

.empty-state button {
  margin-top: 38rpx;
  background: #58cc02;
  color: #ffffff;
  border-bottom: 8rpx solid #46a302;
}

.primary-action::after,
.secondary-action::after,
.empty-state button::after {
  border: 0;
}
